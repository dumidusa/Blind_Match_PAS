@model List<BlindMatchPAS.Models.Project>
@{
    ViewData["Title"] = "Module Leader Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-8 max-w-7xl font-sans">
    
    <div class="mb-8 border-b border-gray-200 pb-4">
        <h2 class="text-2xl font-semibold text-gray-800 flex items-center gap-2">
             Module Leader Dashboard
        </h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-r-lg mb-6 flex justify-between items-center shadow-sm" role="alert">
            <span class="block sm:inline font-medium">@TempData["Success"]</span>
            <button type="button" class="text-green-700 hover:text-green-900 text-xl font-bold leading-none focus:outline-none" onclick="this.parentElement.style.display='none'">
                &times;
            </button>
        </div>
    }
    
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-r-lg mb-6 flex justify-between items-center shadow-sm" role="alert">
            <span class="block sm:inline font-medium">@TempData["Error"]</span>
            <button type="button" class="text-red-700 hover:text-red-900 text-xl font-bold leading-none focus:outline-none" onclick="this.parentElement.style.display='none'">
                &times;
            </button>
        </div>
    }

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-10">
        <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm hover:shadow-md hover:border-orange-200 transition-all duration-200 group">
            <p class="text-gray-500 text-xs font-bold uppercase tracking-wider mb-1 group-hover:text-orange-500 transition-colors">Total Students</p>
            <h3 class="text-3xl font-bold text-gray-800">@ViewBag.TotalStudents</h3>
        </div>
        
        <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm hover:shadow-md hover:border-orange-200 transition-all duration-200 group">
            <p class="text-gray-500 text-xs font-bold uppercase tracking-wider mb-1 group-hover:text-orange-500 transition-colors">Supervisors</p>
            <h3 class="text-3xl font-bold text-gray-800">@ViewBag.TotalSupervisors</h3>
        </div>
        
        <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm hover:shadow-md hover:border-orange-200 transition-all duration-200 group">
            <p class="text-gray-500 text-xs font-bold uppercase tracking-wider mb-1 group-hover:text-orange-500 transition-colors">Pending Matches</p>
            <h3 class="text-3xl font-bold text-orange-500">@ViewBag.TotalPending</h3>
        </div>
        
        <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm hover:shadow-md hover:border-orange-200 transition-all duration-200 group">
            <p class="text-gray-500 text-xs font-bold uppercase tracking-wider mb-1 group-hover:text-orange-500 transition-colors">Confirmed Matches</p>
            <h3 class="text-3xl font-bold text-gray-800">@ViewBag.TotalMatched</h3>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
        <a asp-action="UserManagement" class="flex items-center justify-center gap-2 w-full bg-white border border-gray-200 text-gray-700 hover:text-orange-600 hover:border-orange-500 rounded-xl py-3.5 font-medium transition-all shadow-sm">
             Manage Users
        </a>
        <a asp-action="ResearchAreas" class="flex items-center justify-center gap-2 w-full bg-white border border-gray-200 text-gray-700 hover:text-orange-600 hover:border-orange-500 rounded-xl py-3.5 font-medium transition-all shadow-sm">
             Research Areas
        </a>
        <a asp-action="AllAllocations" class="flex items-center justify-center gap-2 w-full bg-orange-500 border border-orange-500 text-white hover:bg-orange-600 hover:border-orange-600 rounded-xl py-3.5 font-medium transition-all shadow-sm">
             View All Matches
        </a>
    </div>

    <div class="flex items-center justify-between mb-4">
        <h4 class="text-lg font-semibold text-gray-800">Recent Matches</h4>
    </div>
    
    @if (!Model.Any())
    {
        <div class="bg-white border border-gray-200 text-gray-500 px-6 py-8 rounded-xl shadow-sm text-center italic">
            No matches have been confirmed yet.
        </div>
    }
    else
    {
        <div class="overflow-x-auto bg-white rounded-xl shadow-sm border border-gray-200">
            <table class="min-w-full text-left border-collapse">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Project Title</th>
                        <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Research Area</th>
                        <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Student</th>
                        <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Supervisor</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var p in Model)
                    {
                        <tr class="hover:bg-orange-50/50 transition-colors duration-150">
                            <td class="py-4 px-6 align-middle text-gray-800 font-medium">
                                @p.Title
                            </td>
                            <td class="py-4 px-6 align-middle">
                                <span class="inline-block bg-orange-100 text-orange-800 text-xs font-semibold px-2.5 py-1 rounded-md border border-orange-200">
                                    @p.ResearchArea?.Name
                                </span>
                            </td>
                            <td class="py-4 px-6 align-middle">
                                <div class="text-gray-900 font-medium text-sm">@p.Student?.FullName</div>
                                <div class="text-xs text-gray-500 mt-0.5">@p.Student?.Email</div>
                            </td>
                            <td class="py-4 px-6 align-middle">
                                <div class="text-gray-900 font-medium text-sm">@p.MatchedSupervisor?.FullName</div>
                                <div class="text-xs text-gray-500 mt-0.5">@p.MatchedSupervisor?.Email</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
