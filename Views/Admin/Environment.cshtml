@model BlindMatchPAS.ViewModels.EnvironmentViewModel
@{
    ViewData["Title"] = "Environment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-8 max-w-2xl font-sans">
    
    <div class="mb-8 border-b border-gray-200 pb-4">
        <h2 class="text-2xl font-semibold text-gray-800 flex items-center gap-2">
             Environment Configuration
        </h2>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-8">
        <table class="min-w-full text-left border-collapse">
            <tbody class="divide-y divide-gray-200">
                <tr class="hover:bg-orange-50/30 transition-colors">
                    <th class="py-4 px-6 text-sm font-semibold text-gray-700 bg-gray-50 border-r border-gray-200 w-1/3">
                        .NET Version
                    </th>
                    <td class="py-4 px-6 text-sm text-gray-800 font-medium">
                        @Model.DotNetVersion
                    </td>
                </tr>
                <tr class="hover:bg-orange-50/30 transition-colors">
                    <th class="py-4 px-6 text-sm font-semibold text-gray-700 bg-gray-50 border-r border-gray-200">
                        Operating System
                    </th>
                    <td class="py-4 px-6 text-sm text-gray-800 font-medium">
                        @Model.OS
                    </td>
                </tr>
                <tr class="hover:bg-orange-50/30 transition-colors">
                    <th class="py-4 px-6 text-sm font-semibold text-gray-700 bg-gray-50 border-r border-gray-200">
                        Environment
                    </th>
                    <td class="py-4 px-6 text-sm">
                        <span class="inline-block text-xs font-bold px-2.5 py-1 rounded-md border @(Model.EnvironmentName == "Production" ? "bg-red-100 text-red-800 border-red-200" : "bg-yellow-100 text-yellow-800 border-yellow-200")">
                            @Model.EnvironmentName
                        </span>
                    </td>
                </tr>
                <tr class="hover:bg-orange-50/30 transition-colors">
                    <th class="py-4 px-6 text-sm font-semibold text-gray-700 bg-gray-50 border-r border-gray-200">
                        Database Connected
                    </th>
                    <td class="py-4 px-6 text-sm">
                        @if (Model.DatabaseConnected)
                        {
                            <span class="inline-flex items-center gap-1 bg-green-100 text-green-800 border border-green-200 text-xs font-bold px-2.5 py-1 rounded-md">
                                <span>&#10003;</span> Connected
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-1 bg-red-100 text-red-800 border border-red-200 text-xs font-bold px-2.5 py-1 rounded-md">
                                <span>&#10007;</span> Disconnected
                            </span>
                        }
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="flex">
        <a asp-action="Index" class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:text-orange-600 transition-colors shadow-sm gap-2">
            <span>←</span> Back to Dashboard
        </a>
    </div>
</div>