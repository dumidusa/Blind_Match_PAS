 <!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – BlindMatch PAS</title>

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                             50:  '#fff7ed',
                             100: '#ffedd5',
                             200: '#fed7aa',
                             300: '#fdba74',
                             400: '#fb923c',
                             500: '#f97316',
                             600: '#ea580c',
                             700: '#c2410c',
                             800: '#9a3412',
                            900: '#7c2d12',
                        },
                        slate: {
                            950: '#0b1120',
                        }
                    },
                    fontFamily: {
                        display: ['"DM Sans"', 'system-ui', 'sans-serif'],
                        body:    ['"DM Sans"', 'system-ui', 'sans-serif'],
                    },
                    boxShadow: {
                        glass: '0 8px 32px 0 rgba(21, 64, 232, 0.10)',
                        card:  '0 2px 16px 0 rgba(11, 17, 32, 0.08)',
                    }
                }
            }
        }
    </script>

    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body { font-family: 'DM Sans', system-ui, sans-serif; }
    </style>
</head>

<body class="h-full bg-slate-50 text-slate-900 antialiased">
@if (ViewData["HideNav"] == null)
{
<!-- ───── TOP NAVIGATION ───── -->
<header class="sticky top-0 z-40 bg-white border-b border-brand-200 shadow-sm">    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">

            <!-- Logo -->
            <a asp-controller="Auth" asp-action="Login" class="flex items-center gap-2.5 group">
                <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center shadow-sm group-hover:bg-brand-700 transition-colors">
                    <svg class="w-4 h-4 text-white" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                        <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                    </svg>
                </div>
                <span class="font-bold text-lg text-slate-900">
                    BlindMatch <span class="text-brand-600">PAS</span>
                </span>
            </a>

            <!-- Authenticated -->
            @if (User.Identity?.IsAuthenticated == true)
            {
                <nav class="hidden md:flex items-center gap-6">
                    @if (User.IsInRole("Student"))
                    {
                        <a asp-controller="Student" asp-action="Index"
                           class="text-slate-600 hover:text-brand-600 font-medium text-sm transition">
                            Dashboard
                        </a>
                    }
                    @if (User.IsInRole("Supervisor"))
                    {
                        <a asp-controller="Supervisor" asp-action="Index"
                           class="text-slate-600 hover:text-brand-600 font-medium text-sm transition">
                            Dashboard
                        </a>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Index"
                           class="text-slate-600 hover:text-brand-600 font-medium text-sm transition">
                            Dashboard
                        </a>
                    }
                    @if (User.IsInRole("ModuleLeader"))
                    {
                        <a asp-controller="ModuleLeader" asp-action="Index"
                           class="text-slate-600 hover:text-brand-600 font-medium text-sm transition">
                            Dashboard
                        </a>
                    }
                </nav>

                <!-- User info -->
                <div class="flex items-center gap-3">

                    <div class="hidden sm:flex flex-col items-end">
                        <span class="text-sm font-semibold text-slate-800">
                            @User.Identity.Name
                        </span>

                        @{
                            var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
                            var roleClass = role switch
                            {
                                "Admin"        => "bg-rose-100 text-rose-700",
                                "Supervisor"   => "bg-brand-100 text-brand-700",
                                "ModuleLeader" => "bg-amber-100 text-amber-700",
                                _              => "bg-brand-100 text-brand-700"
                            };

                            var roleLabel = role switch
                            {
                                "ModuleLeader" => "Module Leader",
                                _ => role
                            };
                        }

                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold @roleClass">
                            @roleLabel
                        </span>
                    </div>

                    <a asp-controller="Auth" asp-action="Logout"
                       class="inline-flex items-center px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-100 rounded-xl border border-slate-200 transition">
                        Logout
                    </a>
                </div>
            }
            else
            {
                <div class="flex items-center gap-2">
                    <a asp-controller="Auth" asp-action="Login"
                       class="px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 rounded-xl transition">
                        Sign in
                    </a>

                    <a asp-controller="Auth" asp-action="Register"
                       class="px-4 py-2 text-sm font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition">
                        Register
                    </a>
                </div>
            }

        </div>
    </div>
</header>
}
<!-- MAIN -->
<main class="min-h-[calc(100vh-4rem)]">
    @RenderBody()
</main>

<!-- FOOTER -->
<footer class="border-t border-slate-200 bg-white mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex justify-between">
        <p class="text-xs text-slate-400">
            © @DateTime.Now.Year BlindMatch PAS
        </p>
        <p class="text-xs text-slate-400">
            ASP.NET Core + Tailwind
        </p>
    </div>
</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

@RenderSection("Scripts", required: false)

</body>
</html>