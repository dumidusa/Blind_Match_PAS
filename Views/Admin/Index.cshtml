@model BlindMatchPAS.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-8 max-w-7xl font-sans">
    
    <div class="mb-8 border-b border-gray-200 pb-4">
        <h2 class="text-2xl font-semibold text-gray-800 flex items-center gap-2">
             Admin Dashboard
        </h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-r-lg mb-6 flex justify-between items-center shadow-sm" role="alert">
            <span class="block sm:inline font-medium">@TempData["Success"]</span>
            <button type="button" class="text-green-700 hover:text-green-900 text-xl font-bold leading-none focus:outline-none" onclick="this.parentElement.style.display='none'">
                &times;
            </button>
        </div>
    }

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
        <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm hover:shadow-md hover:border-orange-200 transition-all duration-200 group">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-xs font-bold uppercase tracking-wider mb-1 group-hover:text-orange-500 transition-colors">Total Users</p>
                    <h3 class="text-3xl font-bold text-gray-800">@Model.TotalUsers</h3>
                </div>
                <div class="p-3 bg-orange-50 rounded-lg text-orange-500">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg>
                </div>
            </div>
        </div>
        
        <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm hover:shadow-md hover:border-orange-200 transition-all duration-200 group">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-xs font-bold uppercase tracking-wider mb-1 group-hover:text-orange-500 transition-colors">Total Projects</p>
                    <h3 class="text-3xl font-bold text-gray-800">@Model.TotalProjects</h3>
                </div>
                <div class="p-3 bg-orange-50 rounded-lg text-orange-500">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <h4 class="text-lg font-semibold text-gray-800 mb-4">Administrative Actions</h4>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        
        <a asp-action="Users" class="flex flex-col items-center justify-center p-5 bg-white border border-gray-200 rounded-xl hover:border-orange-500 hover:text-orange-600 transition-all shadow-sm group">
            <span class="text-sm font-medium text-gray-700 group-hover:text-orange-600">Manage Users</span>
        </a>
        
        <a asp-action="CreateUser" class="flex flex-col items-center justify-center p-5 bg-orange-500 border border-orange-500 text-white rounded-xl hover:bg-orange-600 hover:border-orange-600 transition-all shadow-sm group">
            <span class="text-2xl mb-2 group-hover:scale-110 transition-transform">+</span>
            <span class="text-sm font-medium text-white">Create User</span>
        </a>
        
        <a asp-action="Environment" class="flex flex-col items-center justify-center p-5 bg-white border border-gray-200 rounded-xl hover:border-orange-500 hover:text-orange-600 transition-all shadow-sm group">
            <span class="text-sm font-medium text-gray-700 group-hover:text-orange-600">Environment</span>
        </a>
        
        <a asp-action="Migrations" class="flex flex-col items-center justify-center p-5 bg-white border border-gray-200 rounded-xl hover:border-orange-500 hover:text-orange-600 transition-all shadow-sm group">
            <span class="text-sm font-medium text-gray-700 group-hover:text-orange-600">Migrations</span>
        </a>
        
        <a asp-action="RbacAudit" class="flex flex-col items-center justify-center p-5 bg-white border border-gray-200 rounded-xl hover:border-red-500 hover:text-red-600 transition-all shadow-sm group">
            <span class="text-sm font-medium text-gray-700 group-hover:text-red-600">RBAC Audit</span>
        </a>

    </div>
</div>