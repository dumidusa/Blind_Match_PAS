@model BlindMatchPAS.ViewModels.MigrationsViewModel
@{
    ViewData["Title"] = "Database Migrations";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-8 max-w-3xl font-sans">
    
    <div class="mb-8 border-b border-gray-200 pb-4">
        <h2 class="text-2xl font-semibold text-gray-800 flex items-center gap-2">
             Database Migrations
        </h2>
    </div>

    <div class="mb-10">
        <h5 class="text-lg font-semibold text-gray-800 flex items-center gap-2 mb-4">
            <span class="text-green-500">&#10003;</span> Applied Migrations (@Model.AppliedMigrations.Count)
        </h5>
        
        @if (Model.AppliedMigrations.Any())
        {
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <ul class="divide-y divide-gray-100">
                    @foreach (var m in Model.AppliedMigrations)
                    {
                        <li class="px-5 py-3 bg-green-50/50 hover:bg-green-50 transition-colors text-green-800 text-sm font-medium">
                            @m
                        </li>
                    }
                </ul>
            </div>
        }
        else
        {
            <div class="bg-white border border-gray-200 text-gray-500 px-6 py-6 rounded-xl shadow-sm text-center italic text-sm">
                None applied yet.
            </div>
        }
    </div>

    <div class="mb-10">
        <h5 class="text-lg font-semibold text-gray-800 flex items-center gap-2 mb-4">
            <span class="text-yellow-500">&#9888;</span> Pending Migrations (@Model.PendingMigrations.Count)
        </h5>
        
        @if (Model.PendingMigrations.Any())
        {
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-4">
                <ul class="divide-y divide-gray-100">
                    @foreach (var m in Model.PendingMigrations)
                    {
                        <li class="px-5 py-3 bg-yellow-50/50 hover:bg-yellow-50 transition-colors text-yellow-800 text-sm font-medium">
                            @m
                        </li>
                    }
                </ul>
            </div>
            <div class="bg-yellow-50 border-l-4 border-yellow-500 text-yellow-800 p-4 rounded-r-lg shadow-sm text-sm font-medium">
                Run <code class="bg-yellow-100 px-1.5 py-0.5 rounded font-mono text-yellow-900 border border-yellow-200">dotnet ef database update</code> in terminal to apply pending migrations.
            </div>
        }
        else
        {
            <div class="bg-white border border-gray-200 text-gray-500 px-6 py-6 rounded-xl shadow-sm text-center italic text-sm">
                Database is up to date.
            </div>
        }
    </div>

    <div class="flex mt-4 border-t border-gray-200 pt-6">
        <a asp-action="Index" class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:text-orange-600 transition-colors shadow-sm gap-2">
            <span>←</span> Back to Dashboard
        </a>
    </div>
</div>