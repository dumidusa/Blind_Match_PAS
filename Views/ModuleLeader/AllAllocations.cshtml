@model List<BlindMatchPAS.Models.Project>
@{
    ViewData["Title"] = "All Allocations";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-8 max-w-7xl font-sans">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 border-b border-gray-200 pb-4 gap-4">
        <h2 class="text-2xl font-semibold text-gray-800 flex items-center gap-2">
            All Matched Allocations
        </h2>
        <a asp-action="Index" class="text-sm font-medium text-gray-600 hover:text-orange-600 bg-white hover:bg-orange-50 px-4 py-2 rounded-lg transition-colors border border-gray-200 shadow-sm flex items-center gap-2">
            <span>←</span> Back to Dashboard
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-r-lg mb-6 flex justify-between items-center shadow-sm" role="alert">
            <span class="block sm:inline font-medium">@TempData["Success"]</span>
            <button type="button" class="text-green-700 hover:text-green-900 text-xl font-bold leading-none focus:outline-none" onclick="this.parentElement.style.display='none'">
                &times;
            </button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-r-lg mb-6 flex justify-between items-center shadow-sm" role="alert">
            <span class="block sm:inline font-medium">@TempData["Error"]</span>
            <button type="button" class="text-red-700 hover:text-red-900 text-xl font-bold leading-none focus:outline-none" onclick="this.parentElement.style.display='none'">
                &times;
            </button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="bg-white border border-gray-200 text-gray-500 px-6 py-8 rounded-xl shadow-sm text-center italic">
            No confirmed matches yet.
        </div>
    }
    else
    {
        <p class="text-gray-500 mb-4 text-sm font-medium">
            Total matched projects: <strong class="text-gray-800 text-base">@Model.Count</strong>
        </p>

        <div class="overflow-x-auto bg-white rounded-xl shadow-sm border border-gray-200">
            <table class="min-w-full text-left border-collapse">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Project Title</th>
                        <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Research Area</th>
                        <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Student</th>
                        <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Supervisor</th>
                        <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var p in Model)
                    {
                        <tr class="hover:bg-orange-50/50 transition-colors duration-150 group">
                            <td class="py-4 px-6 align-middle">
                                <div class="text-gray-800 font-semibold text-sm">@p.Title</div>
                                <div class="text-xs text-gray-400 mt-1 font-medium">@p.TechStack</div>
                            </td>
                            <td class="py-4 px-6 align-middle">
                                <span class="inline-block bg-orange-100 text-orange-800 text-xs font-semibold px-2.5 py-1 rounded-md border border-orange-200">
                                    @p.ResearchArea?.Name
                                </span>
                            </td>
                            <td class="py-4 px-6 align-middle">
                                <div class="text-gray-900 font-medium text-sm">@p.Student?.FullName</div>
                                <div class="text-xs text-gray-500 mt-0.5">@p.Student?.Email</div>
                            </td>
                            <td class="py-4 px-6 align-middle">
                                <div class="text-gray-900 font-medium text-sm">@p.MatchedSupervisor?.FullName</div>
                                <div class="text-xs text-gray-500 mt-0.5">@p.MatchedSupervisor?.Email</div>
                            </td>
                            <td class="py-4 px-6 align-middle text-center whitespace-nowrap">
                                
                                <form asp-action="UnmatchProject" method="post" class="inline-block" onsubmit="return confirm('Unmatch this project? It will return to Pending status.');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button type="submit" class="px-3 py-1.5 text-xs font-semibold text-gray-600 bg-white border border-gray-300 rounded-lg hover:text-red-600 hover:border-red-500 hover:bg-red-50 transition-colors shadow-sm mr-2">
                                        Unmatch
                                    </button>
                                </form>

                                <button type="button" class="reassign-btn px-3 py-1.5 text-xs font-semibold text-orange-600 bg-white border border-orange-400 rounded-lg hover:text-white hover:bg-orange-500 hover:border-orange-500 transition-colors shadow-sm"
                                        data-project-id="@p.Id"
                                        data-project-title="@p.Title">
                                    Reassign
                                </button>

                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div id="reassignModal" class="fixed inset-0 z-50 hidden bg-gray-900/60 backdrop-blur-sm flex items-center justify-center p-4 transition-opacity">
    <div class="bg-white rounded-xl shadow-2xl max-w-md w-full overflow-hidden border border-gray-100 transform transition-all">
        
        <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
            <h5 class="text-lg font-semibold text-gray-800">Reassign Project</h5>
            <button type="button" class="close-modal text-gray-400 hover:text-gray-600 text-xl font-bold focus:outline-none">&times;</button>
        </div>
        
        <form asp-action="ReassignProject" method="post">
            @Html.AntiForgeryToken()
            <div class="p-6">
                <p class="text-sm text-gray-600 mb-4">Reassigning: <strong id="modalProjectTitle" class="text-gray-800 block mt-1 truncate"></strong></p>
                <input type="hidden" name="ProjectId" id="modalProjectId" />
                
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Select New Supervisor</label>
                    <select name="SupervisorId" class="w-full border-gray-300 text-gray-700 rounded-lg shadow-sm focus:ring-orange-500 focus:border-orange-500 text-sm py-2.5 px-3 border bg-white" required>
                        <option value="">-- Choose a supervisor --</option>
                        @foreach (var sup in ViewBag.Supervisors as List<BlindMatchPAS.Models.User> ?? new())
                        {
                            <option value="@sup.Id">@sup.FullName (@sup.Email)</option>
                        }
                    </select>
                </div>
            </div>
            
            <div class="px-6 py-4 border-t border-gray-100 flex justify-end gap-3 bg-gray-50">
                <button type="button" class="close-modal px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors shadow-sm">
                    Cancel
                </button>
                <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-orange-500 border border-orange-500 rounded-lg hover:bg-orange-600 transition-colors shadow-sm">
                    Confirm Reassign
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const modal = document.getElementById('reassignModal');
            const modalProjectId = document.getElementById('modalProjectId');
            const modalProjectTitle = document.getElementById('modalProjectTitle');
            const closeBtns = document.querySelectorAll('.close-modal');

            document.querySelectorAll('.reassign-btn').forEach(btn => {
                btn.addEventListener('click', function () {
                    modalProjectId.value = this.getAttribute('data-project-id');
                    modalProjectTitle.textContent = this.getAttribute('data-project-title');
                    modal.classList.remove('hidden');
                });
            });

            const closeModal = () => {
                modal.classList.add('hidden');
            };

            closeBtns.forEach(btn => {
                btn.addEventListener('click', closeModal);
            });

            window.addEventListener('click', function (e) {
                if (e.target === modal) {
                    closeModal();
                }
            });
        });
    </script>
}