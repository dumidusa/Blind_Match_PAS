@model List<BlindMatchPAS.Models.User>
@{
    ViewData["Title"] = "Users";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-8 max-w-7xl font-sans">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 border-b border-gray-200 pb-4 gap-4">
        <h2 class="text-2xl font-semibold text-gray-800 flex items-center gap-2">
            Users Directory
        </h2>
        <a asp-action="Index" class="text-sm font-medium text-gray-600 hover:text-orange-600 bg-white hover:bg-orange-50 px-4 py-2 rounded-lg transition-colors border border-gray-200 shadow-sm flex items-center gap-2">
            <span>←</span> Back to Dashboard
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-r-lg mb-6 flex justify-between items-center shadow-sm" role="alert">
            <span class="block sm:inline font-medium">@TempData["Success"]</span>
            <button type="button" class="text-green-700 hover:text-green-900 text-xl font-bold leading-none focus:outline-none" onclick="this.parentElement.style.display='none'">
                &times;
            </button>
        </div>
    }

    <form method="get" class="flex flex-col md:flex-row gap-3 mb-6 bg-white p-4 rounded-xl border border-gray-200 shadow-sm items-center">
        <div class="flex-grow w-full md:w-auto">
            <input name="search" value="@Context.Request.Query["search"]"
                   class="w-full border-gray-300 text-gray-700 rounded-lg shadow-sm focus:ring-orange-500 focus:border-orange-500 text-sm py-2.5 px-3 border bg-white" 
                   placeholder="Search email..." />
        </div>
        <div class="w-full md:w-1/4">
            <select name="role" class="w-full border-gray-300 text-gray-700 rounded-lg shadow-sm focus:ring-orange-500 focus:border-orange-500 text-sm py-2.5 px-3 border bg-white">
                <option value="">All Roles</option>
                @if (Context.Request.Query["role"] == "Student") { <option value="Student" selected>Student</option> } else { <option value="Student">Student</option> }
                @if (Context.Request.Query["role"] == "Supervisor") { <option value="Supervisor" selected>Supervisor</option> } else { <option value="Supervisor">Supervisor</option> }
                @if (Context.Request.Query["role"] == "Admin") { <option value="Admin" selected>Admin</option> } else { <option value="Admin">Admin</option> }
            </select>
        </div>
        <div class="flex gap-2 w-full md:w-auto">
            <button type="submit" class="w-full md:w-auto px-5 py-2.5 text-sm font-medium text-orange-600 bg-orange-50 border border-orange-200 rounded-lg hover:bg-orange-100 transition-colors">
                Filter
            </button>
            <a asp-action="Users" class="w-full md:w-auto px-5 py-2.5 text-sm font-medium text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors text-center whitespace-nowrap">
                Reset
            </a>
        </div>
        <div class="w-full md:w-auto md:ml-auto">
            <a asp-action="CreateUser" class="flex items-center justify-center w-full md:w-auto px-5 py-2.5 text-sm font-medium text-white bg-orange-500 border border-orange-500 rounded-lg hover:bg-orange-600 transition-colors shadow-sm whitespace-nowrap gap-2">
                <span>+</span> Create User
            </a>
        </div>
    </form>

    <div class="overflow-x-auto bg-white rounded-xl shadow-sm border border-gray-200">
        <table class="min-w-full text-left border-collapse">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider w-24">ID</th>
                    <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Full Name</th>
                    <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
                    <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Role</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="py-8 px-6 text-center text-gray-500 italic text-sm">
                            No users found.
                        </td>
                    </tr>
                }
                @foreach (var u in Model)
                {
                    <tr class="hover:bg-orange-50/50 transition-colors duration-150 group">
                        <td class="py-4 px-6 align-middle text-gray-400 font-mono text-xs">
                            @u.Id.ToString().Substring(0, Math.Min(8, u.Id.ToString().Length))...
                        </td>
                        <td class="py-4 px-6 align-middle">
                            <span class="text-gray-800 font-medium text-sm">@u.FullName</span>
                        </td>
                        <td class="py-4 px-6 align-middle text-gray-600 text-sm">
                            @u.Email
                        </td>
                        <td class="py-4 px-6 align-middle">
                            @{
                                var badgeClass = u.Role switch
                                {
                                    "Admin" => "bg-red-100 text-red-800 border-red-200",
                                    "Supervisor" => "bg-yellow-100 text-yellow-800 border-yellow-200",
                                    _ => "bg-blue-100 text-blue-800 border-blue-200"
                                };
                            }
                            <span class="inline-block text-xs font-semibold px-2.5 py-1 rounded-md border @badgeClass">
                                @u.Role
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>