@model BlindMatchPAS.Models.Project?
@{
    ViewData["Title"] = "Student Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var name = User.Identity?.Name ?? "Student";
    var email = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    @if (TempData["Success"] != null)
    {
        <div class="mb-6 rounded-xl bg-green-50 border border-green-200 text-green-800 px-5 py-3 text-sm font-medium">
             @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-6 rounded-xl bg-red-50 border border-red-200 text-red-800 px-5 py-3 text-sm font-medium">
             @TempData["Error"]
        </div>
    }

    <div class="rounded-2xl bg-gradient-to-r from-brand-600 to-brand-500 p-8 mb-8 relative overflow-hidden shadow-glass">
        <div class="absolute right-0 top-0 w-64 h-64 rounded-full bg-white/5 -translate-y-1/2 translate-x-1/4"></div>
        <div class="relative">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/20 text-white text-xs font-semibold mb-3">
                Student Portal
            </span>
            <h1 class="text-2xl sm:text-3xl font-bold text-white mb-1">Welcome, @name</h1>
            <p class="text-brand-100 text-sm">Manage your research project proposal below.</p>
        </div>
    </div>

    @{
        var statusLabel = Model?.Status ?? "No Proposal";
        var statusColor = statusLabel switch {
            "Pending"     => "bg-amber-50 border-amber-200 text-amber-700",
            "UnderReview" => "bg-blue-50 border-blue-200 text-blue-700",
            "Matched"     => "bg-green-50 border-green-200 text-green-700",
            "Withdrawn"   => "bg-slate-50 border-slate-200 text-slate-500",
            _             => "bg-slate-50 border-slate-200 text-slate-500"
        };
        var supervisorLabel = Model?.Status == "Matched" && Model?.MatchedSupervisor != null
            ? Model.MatchedSupervisor.FullName : "Not Assigned Yet";
    }
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="rounded-xl border @statusColor p-5 flex items-start gap-4">
            <div class="text-2xl"></div>
            <div>
                <p class="text-xs font-medium uppercase tracking-wide opacity-60">Project Status</p>
                <p class="text-base font-semibold mt-0.5">@statusLabel</p>
            </div>
        </div>
        <div class="rounded-xl border bg-slate-50 border-slate-200 text-slate-600 p-5 flex items-start gap-4">
            <div class="text-2xl"></div>
            <div>
                <p class="text-xs font-medium uppercase tracking-wide opacity-60">Supervisor</p>
                <p class="text-base font-semibold mt-0.5">@supervisorLabel</p>
            </div>
        </div>
        <div class="rounded-xl border bg-brand-50 border-brand-200 text-brand-700 p-5 flex items-start gap-4">
            <div class="text-2xl">📅</div>
            <div>
                <p class="text-xs font-medium uppercase tracking-wide opacity-60">Submitted</p>
                <p class="text-base font-semibold mt-0.5">
                    @(Model != null ? Model.SubmittedAt.ToString("dd MMM yyyy") : "—")
                </p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <div class="lg:col-span-2 space-y-6">

            @if (Model == null)
            {
                @* No proposal yet *@
                <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-6">
                    <h2 class="font-bold text-slate-900 mb-4">My Project Proposal</h2>
                    <div class="rounded-xl bg-slate-50 border border-dashed border-slate-200 p-10 text-center">
                        <p class="text-slate-600 text-sm font-medium">No proposal submitted yet</p>
                        <p class="text-slate-400 text-xs mt-1 mb-5">Submit your project idea to get started.</p>
                        <a href="@Url.Action("Submit", "Student")"
                           class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-brand-600 text-white text-sm font-semibold hover:bg-brand-700 transition-colors">
                            + Submit a Proposal
                        </a>
                    </div>
                </div>
            }
            else
            {
                <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-6">
                    <div class="flex items-start justify-between mb-5">
                        <h2 class="font-bold text-slate-900">My Project Proposal</h2>
                        <span class="text-xs px-2.5 py-1 rounded-full font-semibold @statusColor">
                            @Model.Status
                        </span>
                    </div>

                    <div class="space-y-4">
                        <div>
                            <p class="text-xs text-slate-400 uppercase tracking-wide font-medium">Title</p>
                            <p class="text-slate-900 font-semibold mt-0.5">@Model.Title</p>
                        </div>
                        <div>
                            <p class="text-xs text-slate-400 uppercase tracking-wide font-medium">Abstract</p>
                            <p class="text-slate-600 text-sm mt-0.5 leading-relaxed">@Model.Abstract</p>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <p class="text-xs text-slate-400 uppercase tracking-wide font-medium">Tech Stack</p>
                                <p class="text-slate-700 text-sm mt-0.5">@Model.TechStack</p>
                            </div>
                            <div>
                                <p class="text-xs text-slate-400 uppercase tracking-wide font-medium">Research Area</p>
                                <p class="text-slate-700 text-sm mt-0.5">@Model.ResearchArea?.Name</p>
                            </div>
                        </div>
                    </div>

                    @if (Model.Status is not "Matched" and not "UnderReview")
                    {
                        <div class="flex gap-3 mt-6 pt-5 border-t border-slate-100">
                            <a href="@Url.Action("Edit", "Student", new { id = Model.Id })"
                               class="px-4 py-2 rounded-xl bg-brand-50 text-brand-700 text-sm font-semibold hover:bg-brand-100 transition-colors">
                                ✏️ Edit
                            </a>
                            <form asp-action="Withdraw" asp-controller="Student" method="post"
                                  onsubmit="return confirm('Are you sure you want to withdraw this proposal?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit"
                                        class="px-4 py-2 rounded-xl bg-red-50 text-red-600 text-sm font-semibold hover:bg-red-100 transition-colors">
                                     Withdraw
                                </button>
                            </form>
                        </div>
                    }
                </div>

                @if (Model.Status == "Matched" && Model.MatchedSupervisor != null)
                {
                    <div class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl border border-green-200 p-6">
                        <div class="flex items-center gap-3 mb-4">
                        <h2 class="font-bold text-green-900">You've been matched!</h2>
                        </div>
                        <p class="text-sm text-green-700 mb-4">Your supervisor's details have been revealed. Reach out to begin your collaboration.</p>
                        <div class="bg-white rounded-xl border border-green-100 p-4 flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center text-xl font-bold text-green-700">
                                @Model.MatchedSupervisor.FullName[0]
                            </div>
                            <div>
                                <p class="font-semibold text-slate-900">@Model.MatchedSupervisor.FullName</p>
                                <p class="text-sm text-slate-500">@Model.MatchedSupervisor.Email</p>
                                <span class="inline-flex mt-1 px-2 py-0.5 rounded-full bg-green-100 text-green-700 text-xs font-semibold">Supervisor</span>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="space-y-6">
            <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-6">
                <h2 class="font-bold text-slate-900 mb-4">My Profile</h2>
                <div class="flex flex-col items-center text-center gap-3">
                    <div class="w-16 h-16 rounded-2xl bg-brand-100 flex items-center justify-center text-2xl font-bold text-brand-700">
                        @name[0].ToString().ToUpper()
                    </div>
                    <div>
                        <p class="font-semibold text-slate-900">@name</p>
                        <p class="text-xs text-slate-400">@email</p>
                        <span class="inline-flex mt-2 px-2.5 py-1 rounded-full bg-brand-100 text-brand-700 text-xs font-semibold">Student</span>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-6">
                <h2 class="font-bold text-slate-900 mb-3">Status Guide</h2>
                <div class="space-y-2 text-sm">
                    <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-amber-400"></span><span class="text-slate-600"><b>Pending</b> — Awaiting review</span></div>
                    <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-blue-400"></span><span class="text-slate-600"><b>Under Review</b> — Supervisor is reviewing</span></div>
                    <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-green-400"></span><span class="text-slate-600"><b>Matched</b> — Supervisor confirmed</span></div>
                </div>
            </div>
        </div>
    </div>
</div>