@model BlindMatchPAS.ViewModels.ProjectViewModel
@{
    ViewData["Title"] = "Edit Proposal";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="max-w-2xl mx-auto px-4 py-10">
    <div class="mb-6">
        <a href="@Url.Action("Index", "Student")" class="text-sm text-brand-600 hover:text-brand-700 font-medium">← Back to Dashboard</a>
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-8">
        <h1 class="text-2xl font-bold text-slate-900 mb-1">Edit Proposal</h1>
        <p class="text-slate-400 text-sm mb-7">You can edit your proposal while it is in <b>Pending</b> status.</p>

        <form asp-action="Edit" asp-controller="Student" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="space-y-5">
                <div>
                    <label asp-for="Title" class="block text-sm font-semibold text-slate-700 mb-1.5">Project Title</label>
                    <input asp-for="Title" class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent" />
                    <span asp-validation-for="Title" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Abstract" class="block text-sm font-semibold text-slate-700 mb-1.5">Abstract</label>
                    <textarea asp-for="Abstract" rows="5"
                              class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent resize-none"></textarea>
                    <span asp-validation-for="Abstract" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="TechStack" class="block text-sm font-semibold text-slate-700 mb-1.5">Tech Stack</label>
                    <input asp-for="TechStack" class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent" />
                    <span asp-validation-for="TechStack" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="ResearchAreaId" class="block text-sm font-semibold text-slate-700 mb-1.5">Research Area</label>
                    <select asp-for="ResearchAreaId" asp-items="Model.ResearchAreas"
                            class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent bg-white">
                        <option value="">— Select a research area —</option>
                    </select>
                    <span asp-validation-for="ResearchAreaId" class="text-xs text-red-500 mt-1 block"></span>
                </div>
            </div>

            <div class="mt-8 flex gap-3">
                <button type="submit"
                        class="px-6 py-2.5 rounded-xl bg-brand-600 text-white text-sm font-semibold hover:bg-brand-700 transition-colors">
                    Save Changes
                </button>
                <a href="@Url.Action("Index", "Student")"
                   class="px-6 py-2.5 rounded-xl bg-slate-100 text-slate-600 text-sm font-semibold hover:bg-slate-200 transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}