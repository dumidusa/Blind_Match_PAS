@model List<BlindMatchPAS.Models.ResearchArea>
@{
    ViewData["Title"] = "Research Areas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-8 max-w-7xl font-sans">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 border-b border-gray-200 pb-4 gap-4">
        <h2 class="text-2xl font-semibold text-gray-800 flex items-center gap-2">
             Research Areas
        </h2>
        <a asp-action="Index" class="text-sm font-medium text-gray-600 hover:text-orange-600 bg-white hover:bg-orange-50 px-4 py-2 rounded-lg transition-colors border border-gray-200 shadow-sm flex items-center gap-2">
            <span>←</span> Back to Dashboard
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-r-lg mb-6 flex justify-between items-center shadow-sm" role="alert">
            <span class="block sm:inline font-medium">@TempData["Success"]</span>
            <button type="button" class="text-green-700 hover:text-green-900 text-xl font-bold leading-none focus:outline-none" onclick="this.parentElement.style.display='none'">
                &times;
            </button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-r-lg mb-6 flex justify-between items-center shadow-sm" role="alert">
            <span class="block sm:inline font-medium">@TempData["Error"]</span>
            <button type="button" class="text-red-700 hover:text-red-900 text-xl font-bold leading-none focus:outline-none" onclick="this.parentElement.style.display='none'">
                &times;
            </button>
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 mb-10 overflow-hidden">
        <div class="bg-gray-50 border-b border-gray-200 px-6 py-4">
            <h3 class="font-semibold text-gray-800 text-lg">Add New Research Area</h3>
        </div>
        <div class="p-6">
            <form asp-action="AddResearchArea" method="post">
                @Html.AntiForgeryToken()
                <div class="flex flex-col md:flex-row gap-4 items-start md:items-end">
                    <div class="flex-grow w-full md:w-auto">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Area Name</label>
                        <input type="text" name="Name" class="w-full border-gray-300 text-gray-700 rounded-lg shadow-sm focus:ring-orange-500 focus:border-orange-500 text-sm py-2.5 px-3 border bg-white"
                               placeholder="e.g. Artificial Intelligence"
                               pattern="^[a-zA-Z0-9\s\-/()+]+"
                               required maxlength="100" />
                        <p class="text-xs text-gray-500 mt-2">Letters, numbers, spaces, hyphens, slashes, parentheses only.</p>
                    </div>
                    <div class="w-full md:w-auto">
                        <button type="submit" class="w-full md:w-auto px-6 py-2.5 text-sm font-medium text-white bg-orange-500 border border-orange-500 rounded-lg hover:bg-orange-600 hover:border-orange-600 transition-colors shadow-sm whitespace-nowrap">
                            Add Area
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="flex items-center justify-between mb-4">
        <h4 class="text-lg font-semibold text-gray-800">Existing Areas (@Model.Count)</h4>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white border border-gray-200 text-gray-500 px-6 py-8 rounded-xl shadow-sm text-center italic">
            No research areas defined yet.
        </div>
    }
    else
    {
        <div class="overflow-x-auto bg-white rounded-xl shadow-sm border border-gray-200">
            <table class="min-w-full text-left border-collapse">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider w-16">#</th>
                        <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
                        <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var area = Model[i];
                        <tr class="hover:bg-orange-50/50 transition-colors duration-150 group">
                            <td class="py-4 px-6 align-middle text-gray-400 font-medium text-sm">
                                @(i + 1)
                            </td>
                            <td class="py-4 px-6 align-middle">
                                <span class="text-gray-800 font-semibold text-sm">@area.Name</span>
                            </td>
                            <td class="py-4 px-6 align-middle text-right">
                                <form asp-action="DeleteResearchArea" method="post" class="inline-block"
                                      onsubmit="return confirm('Delete \'@area.Name\'? This cannot be undone.');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@area.Id" />
                                    <button type="submit" class="px-3 py-1.5 text-xs font-semibold text-red-600 bg-white border border-red-200 rounded-lg hover:text-white hover:bg-red-500 hover:border-red-500 transition-colors shadow-sm">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>