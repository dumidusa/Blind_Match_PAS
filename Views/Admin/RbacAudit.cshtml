@model List<BlindMatchPAS.ViewModels.RbacUserRow>
@{
    ViewData["Title"] = "RBAC Audit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-8 max-w-7xl font-sans">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 border-b border-gray-200 pb-4 gap-4">
        <h2 class="text-2xl font-semibold text-gray-800 flex items-center gap-2">
             RBAC Audit — Role Assignments
        </h2>
        <a asp-action="Index" class="text-sm font-medium text-gray-600 hover:text-orange-600 bg-white hover:bg-orange-50 px-4 py-2 rounded-lg transition-colors border border-gray-200 shadow-sm flex items-center gap-2">
            <span>←</span> Back to Dashboard
        </a>
    </div>

    <p class="text-gray-600 mb-8 text-sm bg-gray-50 p-4 rounded-lg border border-gray-200">
        This page verifies Role-Based Access Control is correctly assigned. Students cannot access Supervisor or Admin dashboards, and vice versa.
    </p>

    <div class="overflow-x-auto bg-white rounded-xl shadow-sm border border-gray-200 mb-8">
        <table class="min-w-full text-left border-collapse">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
                    <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Role</th>
                    <th class="py-3 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Access Level</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var u in Model)
                {
                    <tr class="hover:bg-orange-50/50 transition-colors duration-150 group">
                        <td class="py-4 px-6 align-middle">
                            <span class="text-gray-800 font-medium text-sm">@u.Email</span>
                        </td>
                        <td class="py-4 px-6 align-middle">
                            @{
                                var badgeClass = u.Role switch
                                {
                                      "Admin"        => "bg-red-100 text-red-800 border-red-200",
                                     "Supervisor"   => "bg-yellow-100 text-yellow-800 border-yellow-200",
                                     "ModuleLeader" => "bg-purple-100 text-purple-800 border-purple-200",
                                      "Student"      => "bg-blue-100 text-blue-800 border-blue-200",
                                      _              => "bg-gray-100 text-gray-800 border-gray-200"
                                };
                            }
                            <span class="inline-block text-xs font-semibold px-2.5 py-1 rounded-md border @badgeClass">
                                @u.Role
                            </span>
                        </td>
                        <td class="py-4 px-6 align-middle text-gray-500 text-sm">
                            @switch (u.Role)
                            {
                                case "Admin":
                                    <text>Full access — Admin, Student &amp; Supervisor dashboards</text>
                                    break;
                                case "Supervisor":
                                    <text>Supervisor dashboard only</text>
                                    break;
                                case "Student":
                                    <text>Student dashboard only</text>
                                    break;
                                case "ModuleLeader":
                                    <text>Module Leader dashboard only</text>
                                     break;
                                default:
                                    <text>Unknown role</text>
                                    break;
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>