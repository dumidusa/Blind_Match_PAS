@model BlindMatchPAS.ViewModels.AdminCreateUserViewModel
@{
    ViewData["Title"] = "Create User";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-8 max-w-lg font-sans">
    
    <div class="mb-8 border-b border-gray-200 pb-4">
        <h2 class="text-2xl font-semibold text-gray-800 flex items-center gap-2">
             Create User
        </h2>
    </div>

    <div asp-validation-summary="ModelOnly" class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-r-lg mb-6 shadow-sm font-medium"></div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <form method="post" class="p-6 sm:p-8">
            @Html.AntiForgeryToken()

            <div class="mb-5">
                <label asp-for="Email" class="block text-sm font-semibold text-gray-700 mb-2"></label>
                <input asp-for="Email" class="w-full border-gray-300 text-gray-700 rounded-lg shadow-sm focus:ring-orange-500 focus:border-orange-500 text-sm py-2.5 px-3 border bg-white" placeholder="user@example.com" />
                <span asp-validation-for="Email" class="text-sm text-red-500 mt-1 block font-medium"></span>
            </div>

            <div class="mb-5">
                <label asp-for="Password" class="block text-sm font-semibold text-gray-700 mb-2"></label>
                <input asp-for="Password" type="password" class="w-full border-gray-300 text-gray-700 rounded-lg shadow-sm focus:ring-orange-500 focus:border-orange-500 text-sm py-2.5 px-3 border bg-white" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-sm text-red-500 mt-1 block font-medium"></span>
            </div>

            <div class="mb-8">
                <label asp-for="Role" class="block text-sm font-semibold text-gray-700 mb-2"></label>
                <select asp-for="Role" class="w-full border-gray-300 text-gray-700 rounded-lg shadow-sm focus:ring-orange-500 focus:border-orange-500 text-sm py-2.5 px-3 border bg-white">
                    <option value="">-- Select Role --</option>
                    <option value="Student">Student</option>
                    <option value="Supervisor">Supervisor</option>
                    <option value="ModuleLeader">Module Leader</option>
                    <option value="Admin">Admin</option>
                </select>
                <span asp-validation-for="Role" class="text-sm text-red-500 mt-1 block font-medium"></span>
            </div>

            <div class="flex flex-col sm:flex-row gap-3 pt-2 border-t border-gray-100 mt-2">
                <button type="submit" class="w-full sm:w-auto px-6 py-2.5 text-sm font-medium text-white bg-orange-500 border border-orange-500 rounded-lg hover:bg-orange-600 hover:border-orange-600 transition-colors shadow-sm text-center">
                    Create User
                </button>
                <a asp-action="Users" class="w-full sm:w-auto px-6 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors shadow-sm text-center flex items-center justify-center">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}