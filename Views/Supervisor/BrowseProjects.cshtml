@{
    ViewData["Title"] = "Blind Review Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var projects         = ViewBag.Projects as List<BlindMatchPAS.Models.Project> ?? new();
    var interestedIds    = ViewBag.InterestedProjectIds as List<int> ?? new();
    var interestCounts   = ViewBag.InterestCounts as Dictionary<int, int> ?? new();
    var allAreas         = ViewBag.AllAreas as List<BlindMatchPAS.Models.ResearchArea> ?? new();
    var expertiseIds     = ViewBag.ExpertiseIds as List<int> ?? new();
    int selectedAreaId   = ViewBag.SelectedAreaId ?? 0;
    string search        = ViewBag.Search ?? "";
}

@if (TempData["Success"] != null)
{
    <div id="toast" class="fixed top-5 right-5 z-50 bg-green-600 text-white px-5 py-3 rounded-xl shadow-lg text-sm font-medium flex items-center gap-2">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div id="toast" class="fixed top-5 right-5 z-50 bg-red-600 text-white px-5 py-3 rounded-xl shadow-lg text-sm font-medium">
         @TempData["Error"]
    </div>
}
@if (TempData["Info"] != null)
{
    <div id="toast" class="fixed top-5 right-5 z-50 bg-blue-600 text-white px-5 py-3 rounded-xl shadow-lg text-sm font-medium">
         @TempData["Info"]
    </div>
}

<div id="confirmModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-xl p-8 max-w-sm w-full mx-4">
        <div class="text-center mb-5">
            <h3 class="text-lg font-bold text-slate-900">Confirm Match?</h3>
            <p class="text-slate-500 text-sm mt-2">You are about to confirm this match. The student's identity will be <strong>permanently revealed</strong> to you, and vice versa. This action cannot be undone.</p>
        </div>
        <form id="confirmForm" method="post" asp-action="ExpressInterest">
            @Html.AntiForgeryToken()
            <input type="hidden" name="projectId" id="modalProjectId" />
            <div class="flex gap-3">
                <button type="submit" class="flex-1 px-4 py-2.5 rounded-xl bg-brand-600 text-white text-sm font-semibold hover:bg-brand-700 transition-colors">
                     Confirm
                </button>
                <button type="button" onclick="closeModal()"
                        class="flex-1 px-4 py-2.5 rounded-xl border border-slate-200 text-slate-600 text-sm font-medium hover:bg-slate-50 transition-colors">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="mb-6 flex items-center justify-between flex-wrap gap-3">
        <div>
            <a asp-action="Index" class="text-sm text-brand-600 hover:underline">← Dashboard</a>
            <h1 class="text-2xl font-bold text-slate-900 mt-1">Blind Review Dashboard</h1>
            <p class="text-slate-500 text-sm mt-0.5">
                 Student identities are hidden. You see only the project content.
            </p>
        </div>
        <a asp-action="InterestedProjects"
           class="text-sm px-4 py-2 rounded-xl border border-brand-300 text-brand-700 font-semibold hover:bg-brand-50 transition-colors">
             My Interested (@interestedIds.Count)
        </a>
    </div>

    <div class="mb-6 flex items-start gap-3 bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-800">
        <div>
            <strong>Blind Review Mode Active</strong> — Student names and IDs are not displayed. Identities are only revealed after you <em>confirm</em> a match.
        </div>
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-5 mb-6">
        <form method="get" asp-action="BrowseProjects" class="flex flex-wrap gap-3 items-end">
            <div class="flex-1 min-w-[200px]">
                <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1 block">Search</label>
                <input type="text" name="search" value="@search"
                       placeholder="Title, abstract, tech stack…"
                       class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400" />
            </div>
            <div>
                <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1 block">Research Area</label>
                <select name="areaId" class="border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
                    <option value="0">@(expertiseIds.Any() ? "My Expertise (default)" : "All Areas")</option>
                    @foreach (var area in allAreas)
                    {
                        <option value="@area.Id" selected="@(selectedAreaId == area.Id)">
                            @area.Name @(expertiseIds.Contains(area.Id) ? "★" : "")
                        </option>
                    }
                </select>
            </div>
            <button type="submit"
                    class="px-5 py-2.5 rounded-xl bg-brand-600 text-white text-sm font-semibold hover:bg-brand-700 transition-colors">
                 Filter
            </button>
            @if (!string.IsNullOrEmpty(search) || selectedAreaId > 0)
            {
                <a asp-action="BrowseProjects" class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-500 text-sm hover:bg-slate-50 transition-colors">Clear</a>
            }
        </form>
    </div>

    @if (!projects.Any())
    {
        <div class="rounded-xl bg-slate-50 border border-dashed border-slate-200 p-12 text-center">
            <p class="text-slate-600 font-medium">No projects found</p>
            <p class="text-slate-400 text-sm mt-1">Try adjusting your filters, or <a asp-action="ManageExpertise" class="text-brand-600 hover:underline">update your expertise areas</a>.</p>
        </div>
    }
    else
    {
        <div class="mb-3 text-sm text-slate-500">Showing <strong>@projects.Count</strong> project@(projects.Count != 1 ? "s" : "")</div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            @foreach (var project in projects)
            {
                bool alreadyInterested = interestedIds.Contains(project.Id);
                int otherCount = interestCounts.ContainsKey(project.Id) ? interestCounts[project.Id] : 0;
                <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-6 flex flex-col gap-4">
                    <div class="flex items-start justify-between gap-2">
                        <div>
                            <h3 class="font-bold text-slate-900 text-base leading-snug">@project.Title</h3>
                            <span class="inline-flex mt-1.5 px-2.5 py-1 rounded-full bg-brand-50 border border-brand-200 text-brand-700 text-xs font-medium">
                                @project.ResearchArea?.Name
                            </span>
                        </div>
                        <span class="shrink-0 text-xs px-2.5 py-1 rounded-full font-semibold
                              @(project.Status == "Pending" ? "bg-slate-100 text-slate-600" : "bg-amber-100 text-amber-700")">
                            @project.Status
                        </span>
                    </div>

                    <p class="text-slate-600 text-sm leading-relaxed line-clamp-3">@project.Abstract</p>

                    <div class="bg-slate-50 rounded-xl px-4 py-2.5 text-xs text-slate-500">
                        <span class="font-semibold text-slate-700">Tech Stack:</span> @project.TechStack
                    </div>

                    @if (otherCount > 0)
                    {
                        <p class="text-xs text-slate-400">👥 @otherCount other supervisor@(otherCount != 1 ? "s" : "") interested</p>
                    }

                    <div class="flex items-center gap-1.5 text-xs text-slate-400">
                         <span>Student identity hidden</span>
                    </div>

                    @if (alreadyInterested)
                    {
                        <div class="flex items-center gap-2 mt-auto">
                            <span class="flex-1 text-center py-2.5 rounded-xl bg-green-100 text-green-700 text-sm font-semibold">
                                 You're Interested
                            </span>
                            <a asp-action="InterestedProjects" class="text-xs text-brand-600 hover:underline font-medium">Manage →</a>
                        </div>
                    }
                    else
                    {
                        <form asp-action="ExpressInterest" method="post" class="mt-auto">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="projectId" value="@project.Id" />
                            <button type="submit"
                                    class="w-full py-2.5 rounded-xl bg-brand-600 text-white text-sm font-semibold hover:bg-brand-700 transition-colors">
                                 Express Interest
                            </button>
                        </form>
                    }
                </div>
            }
        </div>
    }
</div>

<script>
function openModal(projectId) {
    document.getElementById('modalProjectId').value = projectId;
    document.getElementById('confirmModal').classList.remove('hidden');
}
function closeModal() {
    document.getElementById('confirmModal').classList.add('hidden');
}
setTimeout(() => { const t = document.getElementById('toast'); if (t) t.style.display = 'none'; }, 4500);
</script>
